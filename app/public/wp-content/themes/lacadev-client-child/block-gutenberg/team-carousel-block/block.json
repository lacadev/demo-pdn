{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lacadev/team-carousel-block",
  "title": "Team Carousel",
  "category": "lacadev-blocks",
  "icon": "groups",
  "editorScript": "lacadev-block-team-carousel-block-editor",
  "style": "lacadev-block-team-carousel-block",
  "textdomain": "laca",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "sectionTitle": { "type": "string", "default": "" },
    "slides":       { "type": "array",  "default": [] },
    "loop":         { "type": "boolean","default": true },
    "autoplay":     { "type": "boolean","default": false },
    "autoplayDelay":{ "type": "number", "default": 3000 },
    "spaceBetween": { "type": "number", "default": 24 },
    "inactiveScale":{ "type": "number", "default": 60 },
    "bgColor":      { "type": "string", "default": "#ffffff" },
    "labelBg":      { "type": "string", "default": "#F5C518" },
    "labelColor":   { "type": "string", "default": "#1a1a1a" }
  }
}
