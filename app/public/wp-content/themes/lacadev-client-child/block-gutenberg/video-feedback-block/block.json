{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lacadev/video-feedback-block",
  "title": "Video Feedback Slider",
  "category": "lacadev-blocks",
  "icon": "video-alt3",
  "editorScript": "lacadev-block-video-feedback-block-editor",
  "style": "lacadev-block-video-feedback-block",
  "textdomain": "laca",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "heading":        { "type": "string",  "default": "" },
    "videos":         { "type": "array",   "default": [] },
    "slidesPerView":  { "type": "number",  "default": 4 },
    "spaceBetween":   { "type": "number",  "default": 20 },
    "loop":           { "type": "boolean", "default": true },
    "autoplay":       { "type": "boolean", "default": false },
    "autoplayDelay":  { "type": "number",  "default": 3000 },
    "showPagination": { "type": "boolean", "default": true },
    "showNavigation": { "type": "boolean", "default": true }
  }
}
