{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/journey-gallery-block",
    "title": "Journey Gallery",
    "category": "lacadev-blocks",
    "icon": "editor-ol",
    "editorScript": "lacadev-block-block-journey-gallery-editor",
    "style": "lacadev-block-block-journey-gallery",
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": "HÀNH TRÌNH XÂY NHÀ"
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "bgColor": {
            "type": "string",
            "default": ""
        },
        "steps": {
            "type": "array",
            "default": []
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
