{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/contact-form-block",
    "title": "Contact Form Block",
    "category": "lacadev-blocks",
    "icon": "email",
    "editorScript": "lacadev-block-block-contact-form-editor",
    "style": "lacadev-block-block-contact-form",
    "textdomain": "laca",
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": "NHẬN TƯ VẤN NGAY"
        },
        "imageId": {
            "type": "number",
            "default": 0
        },
        "imageUrl": {
            "type": "string",
            "default": ""
        },
        "budgetOptions": {
            "type": "array",
            "default": [
                "Dưới 1 tỷ",
                "1 - 3 tỷ",
                "3 - 5 tỷ",
                "5 - 10 tỷ",
                "Trên 10 tỷ"
            ]
        },
        "buttonText": {
            "type": "string",
            "default": "GỬI YÊU CẦU"
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        },
        "__isPreview": {
            "type": "boolean",
            "default": false
        },
        "subheading": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number",
            "default": 0
        },
        "marginBottom": {
            "type": "number",
            "default": 0
        },
        "paddingTop": {
            "type": "number",
            "default": 60
        },
        "paddingBottom": {
            "type": "number",
            "default": 55
        }
    },
    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    }
}
