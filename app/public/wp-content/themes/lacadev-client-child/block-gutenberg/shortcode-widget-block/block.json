{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/shortcode-widget-block",
    "title": "Shortcode Widget",
    "category": "lacadev-blocks",
    "icon": "shortcode",
    "editorScript": "lacadev-block-shortcode-widget-block-editor",
    "style": "lacadev-block-shortcode-widget-block",
    "textdomain": "laca",
    "supports": {
        "html": false
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "shortcode1": {
            "type": "string",
            "default": ""
        },
        "shortcode2": {
            "type": "string",
            "default": ""
        },
        "bgColor": {
            "type": "string",
            "default": "#0f0f0f"
        },
        "bgOpacity": {
            "type": "number",
            "default": 100
        }
    }
}