{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lacadev/projects-slider-block",
    "version": "1.0.0",
    "title": "Projects Slider Block",
    "category": "lacadev-blocks",
    "description": "Hiển thị danh sách dự án dạng Swiper slider fullwidth — chọn post type, danh mục, số lượng; hỗ trợ auto/manual.",
    "keywords": ["project", "slider", "swiper", "portfolio", "du-an"],
    "textdomain": "laca",

    "supports": {
        "html": false,
        "align": ["wide", "full"]
    },

    "example": {
        "viewportWidth": 800,
        "attributes": {
            "__isPreview": true
        }
    },

    "attributes": {
        "__isPreview": { "type": "boolean", "default": false },

        "sectionBadge": { "type": "string", "default": "Dự Án Tiêu Biểu" },
        "sectionTitle": { "type": "string", "default": "Dự Án Sử Dụng Sản Phẩm" },
        "ctaText":      { "type": "string", "default": "Xem Thêm" },
        "headingColor": { "type": "string", "default": "" },

        "postType":      { "type": "string", "default": "post" },
        "taxonomy":      { "type": "string", "default": "category" },
        "selectedTerms": { "type": "array",  "default": [] },
        "mode":          { "type": "string", "default": "auto" },
        "orderBy":       { "type": "string", "default": "date" },
        "order":         { "type": "string", "default": "DESC" },
        "postsCount":    { "type": "number", "default": 6 },
        "selectedPosts": { "type": "array",  "default": [] },

        "bgColor":      { "type": "string", "default": "#0f0f0f" },
        "bgOpacity":    { "type": "number", "default": 100 },
        "pauseOnHover": { "type": "boolean", "default": true }
    },

    "editorScript": "lacadev-block-projects-slider-block-editor",
    "style":        "lacadev-block-projects-slider-block"
}
